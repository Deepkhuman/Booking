#!/bin/sh
# Pre-commit hook — runs on every git commit
# Blocks commit if type-check or tests fail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${YELLOW}[pre-commit] Running security & quality checks...${NC}"

# ─── 1. Type check ────────────────────────────────────────────────────────────
echo "${YELLOW}[1/3] TypeScript type check...${NC}"
cd backend && npx tsc --noEmit 2>&1
if [ $? -ne 0 ]; then
  echo "${RED}[BLOCKED] TypeScript errors found. Fix before committing.${NC}"
  exit 1
fi
echo "${GREEN}✓ Type check passed${NC}"

# ─── 2. Run all tests ─────────────────────────────────────────────────────────
echo "${YELLOW}[2/3] Running test suite...${NC}"
npm test 2>&1
if [ $? -ne 0 ]; then
  echo "${RED}[BLOCKED] Tests failing. Fix before committing.${NC}"
  exit 1
fi
echo "${GREEN}✓ All tests passed${NC}"

# ─── 3. Security pattern scan ─────────────────────────────────────────────────
echo "${YELLOW}[3/3] Security pattern scan...${NC}"
cd ..
node .github/scripts/security-scan.js
if [ $? -ne 0 ]; then
  echo "${RED}[BLOCKED] Security issues found. Review above and fix before committing.${NC}"
  exit 1
fi
echo "${GREEN}✓ Security scan passed${NC}"

echo "${GREEN}[pre-commit] All checks passed. Proceeding with commit.${NC}"
exit 0
